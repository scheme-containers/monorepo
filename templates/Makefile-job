	cp $(shell guix pack -L ./packages/ -S /opt/gnu/bin=bin {{packages}}) ./scheme.tar.gz
	docker build . -f Dockerfile.fedora --build-arg BANNER="{{{banner}}}" --tag=schemers/{{name}}:latest-fedora

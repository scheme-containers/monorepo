#!/usr/bin/env -S gosh -r7 -A ./snow
; vim: ft=scheme

;; This script reads Scheme implementation install data from data/ directory
;; and builds docker images based on those.

(import (scheme base)
        (scheme read)
        (scheme write)
        (scheme file)
        (scheme process-context)
        (arvyy mustache)
        (srfi 170)
        (gauche process)) ; Not portable!!

(include "util.scm")

(define implementations
  (map (lambda (file)
         (string-copy file 0 (- (string-length file) 4)))
       (directory-files "data")))

(define show-help
  (lambda ()
    (for-each
      display
      '("Usage: build.scm debian/alpine [implementation name] [version]"
        #\newline
        "If no argument is given builds all implementations and versions."
        #\newline))))

;; Handle --help and -h arguments
(when (and (> (length (command-line)) 1)
           (or (string=? (list-ref (command-line) 1) "--help")
               (string=? (list-ref (command-line) 1) "-h")))
  (show-help)
  (exit))

(define dockerfile-debian (compile (slurp "templates/Dockerfile.debian")))
(define dockerfile-alpine (compile (slurp "templates/Dockerfile.alpine")))
(define dockerfile-path
  (lambda (linux implementation)
    (string-append "Dockerfile-generated-" linux "-" implementation)))

;; Choice of linux, this is mandatory
(define linux
  (if (>= (length (command-line)) 2)
    (list-ref (command-line) 1)
    #f))

(when (and (not (string=? linux "debian"))
           (not (string=? linux "alpine")))
  (show-help)
  (exit 1))

;; Limit build to implementation from argument
(define implementation-to-build
  (if (>= (length (command-line)) 3)
    (list-ref (command-line) 2)
    #f))

(when (not (member implementation-to-build implementations string=?))
  (display "Could not find datafile for implementation: ")
  (display implementation-to-build)
  (newline)
  (exit 1))

;; Limit build to version from argument
(define implementation-version-to-build
  (if (>= (length (command-line)) 4)
    (list-ref (command-line) 3)
    #f))

;; Build tag in format schemers/implementation:version-linux
;; or in Debians (default) case schemers/implementation:version
(define make-tag
  (lambda (implementation-name version-name)
    (string-append "schemers/"
                   implementation-name
                   ":"
                   version-name
                   (cond ((string=? linux "alpine") "-alpine")
                         (else "")))))

;; Something in line with:
;; docker build -f Dockerfile . --tag=implementation:version-linux
(define make-docker-command
  (lambda (linux implementation-name version-name)
    `(docker
       build
       -f
       ,(dockerfile-path linux implementation-name)
       "."
       ,(string-append "--tag="
                       (make-tag implementation-name version-name)))))

(for-each
  (lambda (implementation-name)
    (let ((implementation-data
            (with-input-from-file
              (string-append "data/" implementation-name ".scm")
              (lambda () (read)))))
      ;; If user has given implementation as argument build only that
      (when (or (not implementation-to-build)
                (string=? implementation-name implementation-to-build))
        (when (not (assoc implementation-version-to-build
                           (cdr (assoc 'versions implementation-data))
                           string=?))
          (display "Could not find version from datafile: ")
          (display implementation-version-to-build)
          (newline)
          (exit 1))
        (for-each
          (lambda (version)
            (let* ((version-name (car version))
                   (version-data (cdr version))
                   (template-data (append version-data implementation-data))
                   (dockerfile (cond ((string=? linux "debian")
                                      dockerfile-debian)
                                     ((string=? linux "alpine")
                                      dockerfile-alpine)
                                     (else
                                       (show-help)
                                       (exit 1)))))
              ;; If user has given version as argument build only that
              (when (or (not implementation-version-to-build)
                        (string=? version-name
                                  implementation-version-to-build))
                ;; Write to temporary Dockerfile used by all builds
                (with-output-to-file
                  (dockerfile-path linux implementation-name)
                  (lambda ()
                    (display
                      (execute dockerfile template-data))))
                (display "Building tag: ")
                (display (make-tag implementation-name version-name))
                (newline)
                ;; Not portable!
                (when (not (do-process (make-docker-command linux
                                                            implementation-name
                                                            version-name)))
                  (exit 1)))))
          (cdr (assoc 'versions implementation-data))))))
  implementations)
